# Phantom Project — variables de entorno (Vercel / local)
# No subir .env al repositorio. En Vercel: Settings → Environment Variables.

# Supabase (tabla orders)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Discord: canal interno #pedidos-web (webhook)
DISCORD_WEBHOOK_URL=your_discord_webhook_here

# Discord: bot para crear tickets (canal por pedido)
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_server_id_here
DISCORD_CATEGORY_ID=your_category_id_for_tickets_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM_ADDRESS=notificaciones@tudominio.com

# Pagos (ya usados en checkout)
# NOWPAYMENTS_API_KEY=...
# PayPal se configura en checkout.html (SDK client-id)
